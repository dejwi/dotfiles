#!/usr/bin/env bash
set -euo pipefail

IMAGE="${OCX_IMAGE:-opencode-dev:latest}"

if [[ -d "$HOME/dotfiles/.config/opencode/sandbox" ]]; then
  CONTEXT_DIR_DEFAULT="$HOME/dotfiles/.config/opencode/sandbox"
else
  CONTEXT_DIR_DEFAULT="$HOME/.config/opencode/sandbox"
fi

CONTEXT_DIR="${OCX_CONTEXT_DIR:-$CONTEXT_DIR_DEFAULT}"
DOCKERFILE="${OCX_DOCKERFILE:-$CONTEXT_DIR/Dockerfile}"

if [[ -d "$HOME/dotfiles/.config/opencode" ]]; then
  CONFIG_SOURCE_DEFAULT="$HOME/dotfiles/.config/opencode"
else
  CONFIG_SOURCE_DEFAULT="$HOME/.config/opencode"
fi
CONFIG_SOURCE="${OCX_CONFIG_SOURCE:-$CONFIG_SOURCE_DEFAULT}"
CLIPBOARD_IMAGE_DIR="${OCX_CLIPBOARD_IMAGE_DIR:-/tmp/clipboard-images}"
SHARED_OPENCODE_DATA_DIR="${OCX_SHARED_OPENCODE_DATA_DIR:-$HOME/.local/share/opencode}"
LOCAL_OPENCODE_DIST="${OCX_LOCAL_OPENCODE_DIST:-$HOME/projects/opencode/packages/opencode/dist}"
LOCAL_OPENCODE_CONTAINER_BIN="/usr/local/bin/opencode-local"

LOCAL_OPENCODE_BIN=""
WORKTREE_GITDIR_HOST=""
WORKTREE_GIT_COMMON_DIR_HOST=""
WORKTREE_OPENCODE_DB_FILE_HOST=""
WORKTREE_OPENCODE_DB_WAL_FILE_HOST=""
WORKTREE_OPENCODE_DB_SHM_FILE_HOST=""

expand_home_path() {
  local path="$1"
  if [[ "$path" == "~" ]]; then
    printf '%s\n' "$HOME"
  elif [[ "$path" == ~/* ]]; then
    printf '%s/%s\n' "$HOME" "${path#~/}"
  else
    printf '%s\n' "$path"
  fi
}

CLIPBOARD_IMAGE_DIR="$(expand_home_path "$CLIPBOARD_IMAGE_DIR")"
SHARED_OPENCODE_DATA_DIR="$(expand_home_path "$SHARED_OPENCODE_DATA_DIR")"
LOCAL_OPENCODE_DIST="$(expand_home_path "$LOCAL_OPENCODE_DIST")"

resolve_path_from_base() {
  local path="$1"
  local base_dir="$2"
  local resolved_dir=""

  if [[ "$path" == /* ]]; then
    printf '%s\n' "$path"
    return
  fi

  if ! resolved_dir="$(cd "$base_dir/$(dirname "$path")" 2>/dev/null && pwd)"; then
    return 1
  fi

  printf '%s/%s\n' "$resolved_dir" "$(basename "$path")"
}

detect_linked_worktree_git_dirs() {
  local worktree="$1"
  local git_file="$worktree/.git"
  local git_line=""

  WORKTREE_GITDIR_HOST=""
  WORKTREE_GIT_COMMON_DIR_HOST=""

  if [[ ! -f "$git_file" ]]; then
    return
  fi

  IFS= read -r git_line < "$git_file" || true
  if [[ "$git_line" != gitdir:\ * ]]; then
    return
  fi

  local gitdir_raw="${git_line#gitdir: }"
  local gitdir_abs=""
  local commondir_file=""
  local commondir_raw=""
  local common_abs=""

  if ! gitdir_abs="$(resolve_path_from_base "$gitdir_raw" "$worktree")"; then
    echo "Warning: unable to resolve linked gitdir path: $gitdir_raw" >&2
    return
  fi
  if [[ ! -d "$gitdir_abs" ]]; then
    echo "Warning: linked gitdir is missing: $gitdir_abs" >&2
    return
  fi

  commondir_file="$gitdir_abs/commondir"
  if [[ -f "$commondir_file" ]]; then
    IFS= read -r commondir_raw < "$commondir_file" || true
    if [[ -n "$commondir_raw" ]]; then
      if ! common_abs="$(resolve_path_from_base "$commondir_raw" "$gitdir_abs")"; then
        echo "Warning: unable to resolve linked commondir path: $commondir_raw" >&2
        return
      fi
    fi
  fi

  if [[ -z "$common_abs" ]]; then
    common_abs="$gitdir_abs"
  fi

  if [[ ! -d "$common_abs" ]]; then
    echo "Warning: linked common gitdir is missing: $common_abs" >&2
    return
  fi

  WORKTREE_GITDIR_HOST="$gitdir_abs"
  WORKTREE_GIT_COMMON_DIR_HOST="$common_abs"
}

resolve_worktree_opencode_db_file() {
  local worktree="$1"
  local configured_data_dir="${OCX_OPENCODE_DATA_DIR:-opencode-data}"
  local configured_db_path="${OCX_OPENCODE_DB_PATH:-}"
  local resolved_data_dir=""

  if [[ -n "$configured_db_path" ]]; then
    if [[ "$configured_db_path" == /* || "$configured_db_path" == "~" || "$configured_db_path" == ~/* ]]; then
      WORKTREE_OPENCODE_DB_FILE_HOST="$(expand_home_path "$configured_db_path")"
    else
      WORKTREE_OPENCODE_DB_FILE_HOST="$worktree/$configured_db_path"
    fi
  else
    if [[ "$configured_data_dir" == /* || "$configured_data_dir" == "~" || "$configured_data_dir" == ~/* ]]; then
      resolved_data_dir="$(expand_home_path "$configured_data_dir")"
    else
      resolved_data_dir="$worktree/$configured_data_dir"
    fi

    WORKTREE_OPENCODE_DB_FILE_HOST="$resolved_data_dir/opencode.db"
  fi

  mkdir -p "$(dirname "$WORKTREE_OPENCODE_DB_FILE_HOST")"
  touch "$WORKTREE_OPENCODE_DB_FILE_HOST"

  WORKTREE_OPENCODE_DB_WAL_FILE_HOST="${WORKTREE_OPENCODE_DB_FILE_HOST}-wal"
  WORKTREE_OPENCODE_DB_SHM_FILE_HOST="${WORKTREE_OPENCODE_DB_FILE_HOST}-shm"
  touch "$WORKTREE_OPENCODE_DB_WAL_FILE_HOST" "$WORKTREE_OPENCODE_DB_SHM_FILE_HOST"
}

resolve_local_opencode_binary() {
  local use_local="${OCX_USE_LOCAL_OPENCODE:-0}"
  local requested_bin="${OCX_LOCAL_OPENCODE_BIN:-}"
  local docker_arch="${DOCKER_ARCH:-}"
  local candidate=""
  local candidate_path=""
  local candidates=()

  LOCAL_OPENCODE_BIN=""

  if [[ "$use_local" == "0" ]]; then
    return
  fi

  if [[ -n "$requested_bin" ]]; then
    requested_bin="$(expand_home_path "$requested_bin")"
    if [[ -x "$requested_bin" ]]; then
      LOCAL_OPENCODE_BIN="$requested_bin"
    else
      echo "Warning: OCX_LOCAL_OPENCODE_BIN is not executable: $requested_bin" >&2
    fi
    return
  fi

  if [[ "$use_local" == "1" && ! -d "$LOCAL_OPENCODE_DIST" ]]; then
    echo "Warning: OCX_LOCAL_OPENCODE_DIST does not exist: $LOCAL_OPENCODE_DIST" >&2
    return
  fi

  if [[ ! -d "$LOCAL_OPENCODE_DIST" ]]; then
    return
  fi

  if [[ -z "$docker_arch" ]]; then
    docker_arch="$(uname -m)"
  fi

  case "$docker_arch" in
    arm64|aarch64)
      candidates=(
        "opencode-linux-arm64"
        "opencode-linux-arm64-musl"
      )
      ;;
    amd64|x86_64)
      candidates=(
        "opencode-linux-x64"
        "opencode-linux-x64-baseline"
        "opencode-linux-x64-musl"
        "opencode-linux-x64-baseline-musl"
      )
      ;;
    *)
      candidates=(
        "opencode-linux-arm64"
        "opencode-linux-x64"
      )
      ;;
  esac

  for candidate in "${candidates[@]}"; do
    candidate_path="$LOCAL_OPENCODE_DIST/$candidate/bin/opencode"
    if [[ -x "$candidate_path" ]]; then
      LOCAL_OPENCODE_BIN="$candidate_path"
      return
    fi
  done

  if [[ "$use_local" == "1" ]]; then
    echo "Warning: no matching local opencode binary found in $LOCAL_OPENCODE_DIST" >&2
  fi
}

apply_local_opencode_mount() {
  if [[ -z "$LOCAL_OPENCODE_BIN" ]]; then
    return
  fi

  args+=(
    -v "$LOCAL_OPENCODE_BIN:$LOCAL_OPENCODE_CONTAINER_BIN:ro"
    --entrypoint "$LOCAL_OPENCODE_CONTAINER_BIN"
  )
}

help() {
  cat <<'EOF'
ocx - OpenCode sandbox runner

Usage:
  ocx [worktree-path] [opencode-args...]
  ocx shell [worktree-path]
  ocx serve [worktree-path] [--port <host-port>] [--name <container-name>] [-- <serve-args...>]
  ocx serve ls
  ocx serve stop <container>
  ocx build

Examples:
  ocx
  ocx /Users/dawid/projects/nvim-settings/main
  ocx . run "summarize this repo"
  ocx shell .
  ocx serve .
  ocx serve . --port 4400
  ocx serve ls
  ocx build

Environment (optional):
  OCX_IMAGE           Docker image tag (default: opencode-dev:latest)
  OCX_CPUS            Per-container CPU cap (example: 2)
  OCX_MEMORY          Per-container memory cap (example: 4g)
  OCX_PIDS            PID limit (example: 512)
  OCX_RUN_AS_USER     1/0 (default: 0)
  OCX_CONFIG_SOURCE   OpenCode config dir to mount
  OCX_NODE_MODULES_VOLUME 1/0 (default: 1; use Linux-only node_modules volume)
  OCX_PLAYWRIGHT_CACHE_MOUNT 1/0 (default: 0; mount host Playwright cache)
  OCX_CLIPBOARD_IMAGE_MOUNT 1/0 (default: 1; mount clipboard image directory)
  OCX_CLIPBOARD_IMAGE_DIR Host clipboard image dir (default: /tmp/clipboard-images)
  OCX_OPENCODE_DATA_DIR Directory for worktree DB file (default: <worktree>/opencode-data)
  OCX_OPENCODE_DB_PATH Explicit path for worktree DB file (default: <resolved-data-dir>/opencode.db)
  OCX_SHARED_OPENCODE_DATA_DIR Shared opencode data dir (default: ~/.local/share/opencode)
  OCX_GIT_COMMON_RW   1/0 (default: 1; allow writes to shared .git store)
  OCX_USE_LOCAL_OPENCODE 1/0/auto (default: 0; set 1/auto to use local build)
  OCX_LOCAL_OPENCODE_DIST Path to opencode dist root
  OCX_LOCAL_OPENCODE_BIN  Path to an explicit opencode binary
EOF
}

check_docker() {
  if ! docker info >/dev/null 2>&1; then
    echo "Docker daemon is not running (or not reachable)." >&2
    return 1
  fi
}

build_image() {
  check_docker
  docker build -t "$IMAGE" -f "$DOCKERFILE" "$CONTEXT_DIR" --no-cache
}

ensure_image() {
  if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "Image '$IMAGE' not found. Building it now..."
    build_image
  fi
}

ensure_runtime_setup() {
  if [[ ! -d "$CONFIG_SOURCE" ]]; then
    echo "OpenCode config directory not found: $CONFIG_SOURCE" >&2
    exit 1
  fi

  check_docker
  DOCKER_OS="$(docker info --format '{{.OperatingSystem}}' 2>/dev/null || true)"
  DOCKER_ARCH="$(docker info --format '{{.Architecture}}' 2>/dev/null || true)"
  ensure_image
  resolve_local_opencode_binary

  mkdir -p \
    "$SHARED_OPENCODE_DATA_DIR" \
    "$HOME/.cache/opencode" \
    "$HOME/.cache/ms-playwright" \
    "$HOME/.local/share/agent-browser"

  if [[ "${OCX_CLIPBOARD_IMAGE_MOUNT:-1}" == "1" ]]; then
    mkdir -p "$CLIPBOARD_IMAGE_DIR"
  fi
}

apply_runtime_limits() {
  if [[ "${OCX_RUN_AS_USER:-0}" == "1" ]]; then
    args+=(--user "$(id -u):$(id -g)")
  fi

  if [[ -n "${OCX_CPUS:-}" ]]; then
    args+=(--cpus "$OCX_CPUS")
  fi

  if [[ -n "${OCX_MEMORY:-}" ]]; then
    args+=(--memory "$OCX_MEMORY")
  fi

  if [[ -n "${OCX_PIDS:-}" ]]; then
    args+=(--pids-limit "$OCX_PIDS")
  fi
}

node_modules_volume_name() {
  local worktree="$1"
  local worktree_hash

  worktree_hash="$(printf '%s' "$worktree" | shasum -a 256)"
  worktree_hash="${worktree_hash%% *}"
  printf 'ocx-node-modules-%s' "$worktree_hash"
}

prepare_node_modules_volume() {
  local worktree="$1"
  local volume_name

  volume_name="$(node_modules_volume_name "$worktree")"
  docker volume create "$volume_name" >/dev/null
  docker run --rm \
    -v "$volume_name:/node_modules" \
    --entrypoint bash \
    "$IMAGE" \
    -lc 'chmod 0777 /node_modules' >/dev/null
}

apply_common_mounts_and_env() {
  local worktree="$1"
  local node_modules_volume=""
  local git_common_mode="ro"

  detect_linked_worktree_git_dirs "$worktree"
  resolve_worktree_opencode_db_file "$worktree"

  args+=(
    --workdir /workspace
    -e HOME=/home/opencode
    -e XDG_CONFIG_HOME=/home/opencode/.config
    -e XDG_DATA_HOME=/home/opencode/.local/share
    -e XDG_CACHE_HOME=/home/opencode/.cache
    -e AGENT_BROWSER_HOME=/home/opencode/.local/share/agent-browser
    -e PLAYWRIGHT_BROWSERS_PATH=/home/opencode/.cache/ms-playwright
    -e CLIPBOARD_IMAGE_DIR="$CLIPBOARD_IMAGE_DIR"
    -e GIT_CONFIG_COUNT=2
    -e GIT_CONFIG_KEY_0=safe.directory
    -e GIT_CONFIG_VALUE_0=/workspace
    -e GIT_CONFIG_KEY_1=safe.directory
    -e GIT_CONFIG_VALUE_1="$worktree"
    -v "$worktree:/workspace"
    -v "$worktree:$worktree"
    -v "$CONFIG_SOURCE:/home/opencode/.config/opencode"
    -v "$SHARED_OPENCODE_DATA_DIR:/home/opencode/.local/share/opencode"
    -v "$WORKTREE_OPENCODE_DB_FILE_HOST:/home/opencode/.local/share/opencode/opencode.db"
    -v "$WORKTREE_OPENCODE_DB_WAL_FILE_HOST:/home/opencode/.local/share/opencode/opencode.db-wal"
    -v "$WORKTREE_OPENCODE_DB_SHM_FILE_HOST:/home/opencode/.local/share/opencode/opencode.db-shm"
    -v "$HOME/.cache/opencode:/home/opencode/.cache/opencode"
    -v "$HOME/.local/share/agent-browser:/home/opencode/.local/share/agent-browser"
  )

  if [[ -n "$WORKTREE_GITDIR_HOST" && -n "$WORKTREE_GIT_COMMON_DIR_HOST" ]]; then
    if [[ "${OCX_GIT_COMMON_RW:-1}" == "1" ]]; then
      git_common_mode="rw"
    fi

    args+=(
      -v "$WORKTREE_GIT_COMMON_DIR_HOST:$WORKTREE_GIT_COMMON_DIR_HOST:$git_common_mode"
      -v "$WORKTREE_GITDIR_HOST:$WORKTREE_GITDIR_HOST"
    )
  fi

  if [[ "${OCX_CLIPBOARD_IMAGE_MOUNT:-1}" == "1" ]]; then
    args+=(-v "$CLIPBOARD_IMAGE_DIR:$CLIPBOARD_IMAGE_DIR:ro")
  fi

  if [[ "${OCX_PLAYWRIGHT_CACHE_MOUNT:-0}" == "1" ]]; then
    args+=(-v "$HOME/.cache/ms-playwright:/home/opencode/.cache/ms-playwright")
  fi

  if [[ -f "$HOME/.gitconfig" ]]; then
    args+=(-v "$HOME/.gitconfig:/home/opencode/.gitconfig:ro")
  fi

  if [[ -f "$HOME/.npmrc" ]]; then
    args+=(-v "$HOME/.npmrc:/home/opencode/.npmrc:ro")
  fi

  if [[ -d "$HOME/.ssh" ]]; then
    args+=(-v "$HOME/.ssh:/home/opencode/.ssh:ro")
  fi

  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK}" ]]; then
    ssh_auth_sock_source="${SSH_AUTH_SOCK}"

    if [[ "$(uname -s)" == "Darwin" ]] && [[ "${SSH_AUTH_SOCK}" == /private/tmp/com.apple.launchd.*/Listeners ]] && [[ "${DOCKER_OS}" == *"Docker Desktop"* ]]; then
      ssh_auth_sock_source="/run/host-services/ssh-auth.sock"
    fi

    args+=(-v "${ssh_auth_sock_source}:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent)
  fi

  if [[ -n "${OPENCODE_SERVER_PASSWORD:-}" ]]; then
    args+=(-e "OPENCODE_SERVER_PASSWORD=${OPENCODE_SERVER_PASSWORD}")
  fi

  if [[ -n "${OPENCODE_SERVER_USERNAME:-}" ]]; then
    args+=(-e "OPENCODE_SERVER_USERNAME=${OPENCODE_SERVER_USERNAME}")
  fi

  if [[ "${OCX_NODE_MODULES_VOLUME:-1}" == "1" ]]; then
    prepare_node_modules_volume "$worktree"
    node_modules_volume="$(node_modules_volume_name "$worktree")"
    args+=(-v "${node_modules_volume}:/workspace/node_modules")
  fi
}

has_flag() {
  local flag="$1"
  shift
  for arg in "$@"; do
    if [[ "$arg" == "$flag" ]]; then
      return 0
    fi
  done
  return 1
}

serve_list() {
  check_docker
  docker ps \
    --filter label=ocx.mode=serve \
    --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}\t{{.Label "ocx.worktree"}}'
}

serve_stop() {
  local target="${1:-}"

  if [[ -z "$target" ]]; then
    echo "Usage: ocx serve stop <container>" >&2
    exit 1
  fi

  check_docker
  docker stop "$target" >/dev/null
  echo "Stopped $target"
}

start_serve() {
  local worktree="$PWD"
  local serve_port=""
  local serve_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for --port" >&2
          exit 1
        fi
        serve_port="$2"
        shift 2
        ;;
      --name)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for --name" >&2
          exit 1
        fi
        serve_name="$2"
        shift 2
        ;;
      --)
        shift
        break
        ;;
      *)
        if [[ -d "$1" ]]; then
          worktree="$(cd "$1" && pwd)"
          shift
          continue
        fi
        break
        ;;
    esac
  done

  local serve_container_port="4096"
  local serve_cmd=(serve)

  if ! has_flag "--hostname" "$@"; then
    serve_cmd+=(--hostname 0.0.0.0)
  fi

  if ! has_flag "--port" "$@"; then
    serve_cmd+=(--port "$serve_container_port")
  fi

  if [[ $# -gt 0 ]]; then
    serve_cmd+=("$@")
  fi

  if [[ -z "$serve_name" ]]; then
    serve_name="ocx-serve-$(basename "$worktree")-$(date +%H%M%S)"
  fi

  ensure_runtime_setup

  args=(
    docker run -d --init --rm
    --name "$serve_name"
    --label ocx.mode=serve
    --label "ocx.worktree=$worktree"
  )

  if [[ -n "$serve_port" ]]; then
    args+=(-p "127.0.0.1:${serve_port}:${serve_container_port}")
  else
    args+=(-p "127.0.0.1::${serve_container_port}")
  fi

  apply_common_mounts_and_env "$worktree"
  apply_runtime_limits
  apply_local_opencode_mount

  args+=("$IMAGE" "${serve_cmd[@]}")

  local container_id
  container_id="$("${args[@]}")"

  local port_line
  local resolved_port=""
  port_line="$(docker port "$container_id" "${serve_container_port}/tcp" 2>/dev/null || true)"
  if [[ -n "$port_line" ]]; then
    resolved_port="${port_line##*:}"
  fi

  echo "Started ${serve_name}"
  if [[ -n "$resolved_port" ]]; then
    echo "URL: http://127.0.0.1:${resolved_port}"
    echo "OpenAPI: http://127.0.0.1:${resolved_port}/doc"
  fi
  if [[ -n "${OPENCODE_SERVER_PASSWORD:-}" ]]; then
    echo "Auth: ${OPENCODE_SERVER_USERNAME:-opencode} / <OPENCODE_SERVER_PASSWORD>"
  fi
  echo "Stop: ocx serve stop ${serve_name}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  help
  exit 0
fi

if [[ "${1:-}" == "build" ]]; then
  build_image
  exit 0
fi

if [[ "${1:-}" == "serve" ]]; then
  shift
  case "${1:-}" in
    ls|list)
      serve_list
      exit 0
      ;;
    stop)
      shift
      serve_stop "${1:-}"
      exit 0
      ;;
  esac

  start_serve "$@"
  exit 0
fi

MODE="opencode"
if [[ "${1:-}" == "shell" ]]; then
  MODE="shell"
  shift
fi

WORKTREE="$PWD"
if [[ $# -gt 0 && -d "$1" ]]; then
  WORKTREE="$(cd "$1" && pwd)"
  shift
fi

ensure_runtime_setup

args=(
  docker run --rm -it --init
  --name "ocx-$(basename "$WORKTREE")-$(date +%H%M%S)"
)

apply_common_mounts_and_env "$WORKTREE"
apply_runtime_limits

if [[ "$MODE" == "shell" ]]; then
  args+=(--entrypoint bash)
else
  apply_local_opencode_mount
fi

if [[ "$MODE" == "shell" ]]; then
  if [[ $# -gt 0 ]]; then
    args+=("$IMAGE" -lc "$*")
  else
    args+=("$IMAGE" -l)
  fi
else
  args+=("$IMAGE")
  if [[ $# -gt 0 ]]; then
    args+=("$@")
  fi
fi

exec "${args[@]}"
